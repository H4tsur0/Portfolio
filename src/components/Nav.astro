---
const { current = '' } = Astro.props;
const links = [
  { href: '/projects', label: 'Projects' },
  { href: '/books', label: 'Reading list' },
];
---

<nav id="nav" class="nav">
  <div class="nav-inner container">
    <a href="/" class="nav-name">Richard</a>
    <div class="nav-links">
      {links.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { active: current === link.href }]}
        >
          {link.label}
        </a>
      ))}
      <a href="/#contact" class="nav-link nav-contact">Contact</a>
    </div>
  </div>
</nav>

<style>
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  height: var(--nav-height);
  background: transparent;
  border-bottom: 1px solid transparent;
  transition: background 0.4s ease, border-color 0.4s ease;
}

.nav.scrolled {
  background: rgba(13, 17, 19, 0.88);
  border-bottom-color: var(--slate);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.nav-inner {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-name {
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 400;
  color: var(--rock-white);
  letter-spacing: 0.01em;
  transition: color 0.2s;
}

.nav-name:hover { color: var(--foam); }

.nav-links {
  display: flex;
  align-items: center;
  gap: var(--space-xl);
}

.nav-link {
  font-family: var(--font-ui);
  font-size: 0.8rem;
  font-weight: 400;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: rgba(185, 190, 197, 0.5);
  transition: color 0.2s;
}

.nav-link:hover,
.nav-link.active { color: var(--rock-white); }

.nav-contact {
  color: var(--surface);
  opacity: 0.7;
}
.nav-contact:hover { opacity: 1; color: var(--mist); }

/* Mobile */
@media (max-width: 600px) {
  .nav-links { gap: var(--space-lg); }
  .nav-link { font-size: 0.72rem; }
}
</style>

<script>
const nav = document.getElementById('nav');
function onScroll() {
  if (window.scrollY > 60) {
    nav?.classList.add('scrolled');
  } else {
    nav?.classList.remove('scrolled');
  }
}
window.addEventListener('scroll', onScroll, { passive: true });
onScroll();
</script>
