---
const { current = '' } = Astro.props;
const links = [
  { href: '/projects', label: 'Projects' },
  { href: '/#certifications', label: 'Certifications' },
  { href: '/books', label: 'Reading list' },
];
---

<header class="nav-container">
  <nav id="nav" class="nav-pill">
    <a href="/" class="nav-name">Richard</a>
    <div class="nav-links">
      {links.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { active: current === link.href }]}
        >
          {link.label}
        </a>
      ))}
      <a href="/#contact" class="nav-link nav-contact">Contact</a>
    </div>
  </nav>
</header>

<style>
.nav-container {
  position: fixed;
  top: 1.5rem;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  justify-content: center;
  padding: 0 1rem;
  pointer-events: none;
}

.nav-pill {
  pointer-events: auto;
  display: flex;
  align-items: center;
  gap: 2.5rem;
  padding: 0.6rem 2rem;
  background: rgba(13, 17, 19, 0.6);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 100px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  transition: transform 0.3s ease, background 0.3s ease, border-color 0.3s ease;
}

.nav-pill.scrolled {
  background: rgba(13, 17, 19, 0.85);
  border-color: rgba(255, 255, 255, 0.15);
  transform: translateY(-5px) scale(0.98);
}

.nav-name {
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-weight: 400;
  color: var(--rock-white);
  letter-spacing: 0.01em;
  text-decoration: none;
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 1.75rem;
}

.nav-link {
  font-family: var(--font-ui);
  font-size: 0.72rem;
  font-weight: 400;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: rgba(185, 190, 197, 0.6);
  transition: color 0.2s;
  text-decoration: none;
}

.nav-link:hover,
.nav-link.active { 
  color: var(--rock-white); 
}

.nav-contact {
  color: var(--surface);
  opacity: 0.8;
}

/* Mobile */
@media (max-width: 700px) {
  .nav-pill {
    gap: 1.25rem;
    padding: 0.6rem 1.25rem;
  }
  .nav-name { display: none; }
  .nav-links { gap: 1rem; }
  .nav-link { font-size: 0.65rem; }
}
</style>

<script>
const nav = document.getElementById('nav');
function onScroll() {
  if (window.scrollY > 40) {
    nav?.classList.add('scrolled');
  } else {
    nav?.classList.remove('scrolled');
  }
}
window.addEventListener('scroll', onScroll, { passive: true });
onScroll();
</script>
