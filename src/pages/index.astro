---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero';
import ScrollReveal from '../components/ScrollReveal';
import certs from '../data/certifications.json';
import currentlyReading from '../data/currently-reading.json';

// Load featured projects
const projectModules = import.meta.glob('../content/projects/*.md', { eager: true });
const projectFiles = Object.values(projectModules).map((mod: any) => mod.frontmatter ? mod : { frontmatter: mod.default });
const featuredProjects = projectFiles
  .filter((p: any) => p.frontmatter?.featured)
  .sort((a: any, b: any) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime())
  .slice(0, 3);

// Load featured books
const bookModules = import.meta.glob('../content/books/*.md', { eager: true });
const bookFiles = Object.values(bookModules).map((mod: any) => mod.frontmatter ? mod : { frontmatter: mod.default });
const featuredBooks = bookFiles
  .filter((b: any) => b.frontmatter?.featured)
  .slice(0, 3);
---

<Base title="Richard — Portfolio">

  <Hero currentlyReading={currentlyReading} client:load />

  <!-- ── Projects ── -->
  <section class="section-projects" id="projects">
    <div class="container">
      <ScrollReveal client:visible>
        <div class="section-header">
          <p class="section-label">Selected work</p>
          <h2>Projects</h2>
        </div>
      </ScrollReveal>

      <div class="projects-grid">
        {featuredProjects.map((project, i) => (
          <ScrollReveal client:visible delay={i * 0.1}>
            <a
              href={`/projects/${project.frontmatter.slug}`}
              class="project-card card"
            >
              <div class="project-card-top">
                <span class={`tag ${project.frontmatter.status === 'in-progress' ? 'wip' : 'cyber'}`}>
                  {project.frontmatter.status === 'in-progress' ? 'in progress' : project.frontmatter.category}
                </span>
                <span class="project-date mono">{project.frontmatter.date}</span>
              </div>
              <h3 class="project-title">{project.frontmatter.title}</h3>
              <p class="project-desc">{project.frontmatter.description}</p>
              <div class="project-stack">
                {project.frontmatter.stack.slice(0, 4).map(s => (
                  <span class="tag">{s}</span>
                ))}
              </div>
              <div class="project-arrow">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </a>
          </ScrollReveal>
        ))}
      </div>

      <ScrollReveal client:visible delay={0.4}>
        <div class="section-footer">
          <a href="/projects" class="link-more">
            All projects
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- ── Certifications ── -->
  <section class="section-certs" id="certifications">
    <div class="container">
      <ScrollReveal client:visible>
        <div class="section-header">
          <p class="section-label">Credentials</p>
          <h2>Certifications</h2>
        </div>
      </ScrollReveal>

      <div class="certs-timeline">
        {certs.map((cert, i) => (
          <ScrollReveal client:visible delay={i * 0.05} direction="right" distance={20}>
            <div class:list={['cert-item', { 'cert-wip': cert.status === 'in-progress' }]}>
              <div class="cert-left">
                <div class="cert-dot-wrap">
                  <div class="cert-dot"></div>
                  {i < certs.length - 1 && <div class="cert-line"></div>}
                </div>
              </div>
              <div class="cert-body">
                <div class="cert-row">
                  <span class="cert-name">{cert.name}</span>
                  {cert.status === 'in-progress' && <span class="tag wip">in progress</span>}
                </div>
                <div class="cert-meta">
                  <span class="mono">{cert.issuer}</span>
                  <span class="cert-sep mono">·</span>
                  <span class="mono">{cert.date}</span>
                </div>
              </div>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Books ── -->
  <section class="section-books" id="books">
    <div class="container">
      <ScrollReveal client:visible>
        <div class="section-header">
          <p class="section-label philo">Philosophy reading list</p>
          <h2>Books shaping my thinking</h2>
        </div>
      </ScrollReveal>

      <div class="books-grid">
        {featuredBooks.map((book, i) => (
          <ScrollReveal client:visible delay={i * 0.1}>
            <a
              href={`/books/${book.frontmatter.slug}`}
              class="book-card card"
            >
              <div class="book-meta">
                <span class="book-author mono">{book.frontmatter.author}</span>
                <span class="book-year mono">{book.frontmatter.year < 0 ? `${Math.abs(book.frontmatter.year)} BCE` : book.frontmatter.year}</span>
              </div>
              <h3 class="book-title">{book.frontmatter.title}</h3>
              <p class="book-takeaway"><em>"{book.frontmatter.takeaway}"</em></p>
              {book.frontmatter.status === 'reading' && (
                <div class="book-reading-badge">
                  <span class="currently-dot"></span>
                  <span class="mono" style="font-size:0.65rem;color:var(--parchment)">reading now</span>
                </div>
              )}
            </a>
          </ScrollReveal>
        ))}
      </div>

      <ScrollReveal client:visible delay={0.4}>
        <div class="section-footer">
          <a href="/books" class="link-more philo-link">
            Full reading list
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- ── Contact ── -->
  <section class="section-contact" id="contact">
    <div class="container">
      <div class="contact-inner">
        <ScrollReveal client:visible>
          <div class="section-header">
            <p class="section-label">Let's connect</p>
            <h2>Contact</h2>
            <p class="contact-sub">I'm always open to interesting conversations. ask me anything!</p>
          </div>
        </ScrollReveal>

        <div class="contact-links">
          <ScrollReveal client:visible delay={0.1} direction="left" distance={20}>
            <a href="https://github.com/H4tsur0" target="_blank" rel="noopener" class="contact-link">
              <div class="contact-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
              </div>
              <div class="contact-detail">
                <span class="contact-label mono">GitHub</span>
                <span class="contact-handle">@H4tsur0</span>
              </div>
            </a>
          </ScrollReveal>

          <ScrollReveal client:visible delay={0.2} direction="left" distance={20}>
            <a href="https://www.linkedin.com/in/richard-axel-gunawan-654512339" target="_blank" rel="noopener" class="contact-link">
              <div class="contact-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </div>
              <div class="contact-detail">
                <span class="contact-label mono">LinkedIn</span>
                <span class="contact-handle">Richard</span>
              </div>
            </a>
          </ScrollReveal>

          <ScrollReveal client:visible delay={0.3} direction="left" distance={20}>
            <a href="mailto:h4tsur0@gmail.com" class="contact-link">
              <div class="contact-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="4" width="20" height="16" rx="2"/>
                  <path d="M2 7l10 7 10-7"/>
                </svg>
              </div>
              <div class="contact-detail">
                <span class="contact-label mono">Email</span>
                <span class="contact-handle">h4tsur0@gmail.com</span>
              </div>
            </a>
          </ScrollReveal>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
/* ── Hero ── */
:global(.hero) {
  position: relative;
  height: 100vh;
  min-height: 600px;
  display: flex;
  align-items: center;
  justify-content: center;
}

:global(.hero-content) {
  position: relative;
  z-index: 1;
  padding-top: var(--nav-height);
  text-align: center;
}

:global(.hero-text) { 
  max-width: 600px;
  margin: 0 auto;
}

:global(.hero-label) {
  font-size: 0.7rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--surface);
  margin-bottom: var(--space-md);
}

:global(.hero-name) {
  font-size: clamp(3.5rem, 8vw, 6rem);
  font-weight: 400;
  line-height: 1;
  letter-spacing: -0.01em;
  color: var(--rock-white);
  margin-bottom: var(--space-lg);
}

:global(.hero-tagline) {
  font-family: var(--font-body);
  font-size: clamp(1rem, 2vw, 1.2rem);
  color: var(--rock-pale);
  line-height: 1.6;
  margin-bottom: var(--space-xl);
}

:global(.hero-tagline em) { color: var(--mist); font-style: italic; }

:global(.hero-currently) {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  margin-bottom: var(--space-xl);
  padding: 0.6rem 1rem;
  background: rgba(13,17,19,0.5);
  border: 1px solid var(--slate);
  border-radius: 8px;
  width: fit-content;
  backdrop-filter: blur(8px);
}

:global(.currently-dot) {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--parchment);
  flex-shrink: 0;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

:global(.currently-label) {
  font-size: 0.65rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--mist);
}

:global(.currently-title) {
  font-family: var(--font-display);
  font-size: 0.9rem;
  color: var(--vellum);
}

:global(.currently-author) {
  font-size: 0.72rem;
  color: var(--parchment);
}

:global(.hero-cta) {
  display: flex;
  gap: var(--space-md);
  align-items: center;
  justify-content: center;
}

:global(.btn-primary) {
  font-family: var(--font-ui);
  font-size: 0.78rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 0.65rem 1.5rem;
  background: var(--ocean);
  color: var(--foam);
  border: 1px solid var(--wave);
  border-radius: 6px;
  transition: background 0.2s, transform 0.2s;
}
:global(.btn-primary:hover) { background: var(--wave); transform: translateY(-1px); }

:global(.btn-ghost) {
  font-family: var(--font-ui);
  font-size: 0.78rem;
  font-weight: 400;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--rock-light);
  border-bottom: 1px solid transparent;
  transition: color 0.2s, border-color 0.2s;
}
:global(.btn-ghost:hover) { color: var(--rock-white); border-bottom-color: var(--rock-light); }

:global(.hero-scroll-hint) {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 1;
}

:global(.scroll-line) {
  width: 1px;
  height: 48px;
  background: linear-gradient(to bottom, var(--rock-mid), transparent);
  margin: 0 auto;
  animation: scrollPulse 2s ease-in-out infinite;
}

@keyframes scrollPulse {
  0% { opacity: 0; transform: scaleY(0); transform-origin: top; }
  50% { opacity: 1; transform: scaleY(1); }
  100% { opacity: 0; transform: scaleY(1) translateY(10px); }
}

/* ── Section glassmorphism ── */
.section-projects,
.section-books,
.section-certs,
.section-contact {
  padding: var(--space-3xl) 0;
  background: rgba(13, 17, 19, 0.2);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.section-header {
  margin-bottom: var(--space-2xl);
}

.section-header h2 {
  color: var(--rock-white);
}

.section-footer {
  margin-top: var(--space-xl);
}

.link-more {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-family: var(--font-ui);
  font-size: 0.78rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--surface);
  transition: gap 0.2s, color 0.2s;
}
.link-more:hover { gap: 0.7rem; color: var(--mist); }
.link-more.philo-link { color: var(--parchment); }
.link-more.philo-link:hover { color: var(--vellum); }

/* ── Glass Cards ── */
:global(.card) {
  background: rgba(26, 31, 34, 0.4) !important;
  backdrop-filter: blur(8px) !important;
  -webkit-backdrop-filter: blur(8px) !important;
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
  box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
  display: block; /* Ensure the anchor fills the Reveal div */
  height: 100%;
}

:global(.card:hover) {
  background: rgba(26, 31, 34, 0.6) !important;
  border-color: var(--ocean) !important;
}

/* ── Projects ── */
.projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: var(--space-md);
}

.project-card {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  position: relative;
  text-decoration: none;
}

.project-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.project-date { font-size: 0.7rem; }

.project-title {
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 400;
  color: var(--rock-white);
  line-height: 1.3;
}

.project-desc {
  font-family: var(--font-body);
  font-size: 0.85rem;
  color: var(--rock-pale);
  line-height: 1.6;
  flex: 1;
}

.project-stack {
  display: flex;
  gap: 0.4rem;
  flex-wrap: wrap;
}

.project-arrow {
  color: var(--ocean);
  align-self: flex-end;
  opacity: 0;
  transform: translateX(-4px);
  transition: opacity 0.2s, transform 0.2s;
}

.project-card:hover .project-arrow {
  opacity: 1;
  transform: translateX(0);
}

/* ── Books ── */
.books-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: var(--space-md);
}

.book-card {
  text-decoration: none;
}

.book-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 0.5rem;
}

.book-author, .book-year { font-size: 0.7rem; color: var(--parchment); }

.book-title {
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 400;
  color: var(--rock-white);
  margin-bottom: 0.6rem;
  line-height: 1.3;
}

.book-takeaway {
  font-family: var(--font-body);
  font-size: 0.85rem;
  color: var(--rock-pale);
  line-height: 1.6;
  font-style: italic;
}

.book-reading-badge {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  margin-top: 0.75rem;
}

/* ── Certifications ── */
.certs-timeline {
  max-width: 560px;
}

.cert-item {
  display: flex;
  gap: 1rem;
}

.cert-left { display: flex; flex-direction: column; align-items: center; }

.cert-dot-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cert-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--surface);
  flex-shrink: 0;
  margin-top: 6px;
}

.cert-wip .cert-dot { background: var(--ochre); }

.cert-line {
  width: 1px;
  flex: 1;
  background: var(--slate);
  margin: 4px 0;
  min-height: 24px;
}

.cert-body {
  padding: 0 0 1.5rem;
  flex: 1;
}

.cert-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.25rem;
}

.cert-name {
  font-family: var(--font-body);
  font-size: 0.95rem;
  color: var(--rock-white);
}

.cert-wip .cert-name { color: var(--rock-light); }

.cert-meta {
  display: flex;
  align-items: center;
  gap: 0.4rem;
}

.cert-sep { color: var(--rock-light); }

/* ── Contact ── */
.contact-sub {
  max-width: 460px;
  margin-top: 0.75rem;
  font-size: 0.95rem;
}

.contact-links {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  max-width: 400px;
}

.contact-link {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.85rem 1.25rem;
  background: rgba(17, 20, 22, 0.4);
  backdrop-filter: blur(4px);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 10px;
  transition: border-color 0.2s, transform 0.2s, background 0.2s;
  text-decoration: none;
}

.contact-link:hover {
  background: rgba(17, 20, 22, 0.6);
  border-color: var(--ocean);
  transform: translateX(4px);
}

.contact-icon {
  color: var(--surface);
  display: flex;
  align-items: center;
}

.contact-detail {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.contact-label {
  font-size: 0.65rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--mist);
}

.contact-handle {
  font-family: var(--font-body);
  font-size: 0.9rem;
  color: var(--rock-white);
}

/* Mobile */
@media (max-width: 600px) {
  :global(.hero-cta) { flex-direction: column; align-items: center; }
  :global(.hero-currently) { flex-wrap: wrap; }
  .projects-grid, .books-grid { grid-template-columns: 1fr; }
}
</style>
