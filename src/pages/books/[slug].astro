---
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const bookModules = import.meta.glob('../../content/books/*.md', { eager: true });
  const books = Object.values(bookModules).map((mod: any) => mod.frontmatter ? mod : { frontmatter: mod.default });
  return books.map((book: any) => ({
    params: { slug: book.frontmatter.slug },
    props: { book },
  }));
}

const { book } = Astro.props;
const { Content } = book;
const { frontmatter } = book;
---

<Base title={`${frontmatter.title} — Richard Axel Gunawan`} current="/books">
  <article class="container book-detail">
    <header class="book-header">
      <div class="book-meta">
        <span class="mono">{frontmatter.author}</span>
        <span class="mono">·</span>
        <span class="mono">{frontmatter.year < 0 ? `${Math.abs(frontmatter.year)} BCE` : frontmatter.year}</span>
      </div>
      <h1>{frontmatter.title}</h1>
      <div class="book-takeaway-hero">
        <p><em>"{frontmatter.takeaway}"</em></p>
      </div>
    </header>

    <div class="markdown-content">
      <Content />
    </div>

    <footer class="book-footer">
      <a href="/books" class="link-more philo-link">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="transform: rotate(180deg)">
          <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Back to reading list
      </a>
    </footer>
  </article>
</Base>

<style>
.book-detail {
  padding-top: calc(var(--nav-height) + var(--space-3xl));
  padding-bottom: var(--space-3xl);
  max-width: 700px;
}

.book-header {
  margin-bottom: 4rem;
}

.book-meta {
  display: flex;
  gap: 0.75rem;
  color: var(--parchment);
  font-size: 0.8rem;
  margin-bottom: 1rem;
}

.book-header h1 {
  font-size: clamp(2.5rem, 6vw, 4rem);
  color: var(--rock-white);
  margin-bottom: 2rem;
  line-height: 1.1;
}

.book-takeaway-hero {
  padding-left: 1.5rem;
  border-left: 2px solid var(--surface);
  font-size: 1.25rem;
  color: var(--vellum);
  line-height: 1.6;
}

.markdown-content {
  font-family: var(--font-body);
  color: var(--rock-pale);
  line-height: 1.8;
  font-size: 1.05rem;
}

.markdown-content :global(h2) {
  color: var(--rock-white);
  margin-top: 3.5rem;
  margin-bottom: 1.25rem;
  font-family: var(--font-display);
  font-size: 1.6rem;
}

.markdown-content :global(p) { margin-bottom: 1.5rem; }

.markdown-content :global(blockquote) {
  margin: 2.5rem 0;
  padding: 1.5rem 2rem;
  background: var(--depth);
  border-radius: 8px;
  border-left: 4px solid var(--surface);
  font-style: italic;
  color: var(--vellum);
}

.book-footer {
  margin-top: 5rem;
  padding-top: 2rem;
  border-top: 1px solid var(--slate);
}
</style>
