---
import Base from '../../layouts/Base.astro';

const bookModules = import.meta.glob('../../content/books/*.md', { eager: true });
const bookFiles = Object.values(bookModules).map((mod: any) => mod.frontmatter ? mod : { frontmatter: mod.default });
const books = bookFiles.sort((a: any, b: any) => {
  const order = { reading: 0, completed: 1 };
  return (order[a.frontmatter.status] ?? 2) - (order[b.frontmatter.status] ?? 2);
});

const reading = books.filter(b => b.frontmatter.status === 'reading');
const completed = books.filter(b => b.frontmatter.status === 'completed');
---

<Base title="Reading List — Richard Axel Gunawan" current="/books">

  <section class="page-hero">
    <div class="container">
      <p class="section-label philo">Philosophy</p>
      <h1>Reading list</h1>
      <p class="page-sub">
        These are not book reports. They're where I think in public — tracking
        what ideas shifted my perception and what questions I'm still carrying.
      </p>
    </div>
  </section>

  <section class="books-section">
    <div class="container">

      {reading.length > 0 && (
        <div class="books-group">
          <h2 class="group-title">
            <span class="currently-dot"></span>
            Currently reading
          </h2>
          <div class="books-grid">
            {reading.map((book, i) => (
              <a href={`/books/${book.frontmatter.slug}`} class="book-card-full card book-card" style={`animation-delay:${i * 0.1}s`}>
                <div class="bcf-meta">
                  <span class="mono" style="font-size:0.7rem;color:var(--parchment)">{book.frontmatter.author}</span>
                  <span class="mono" style="font-size:0.7rem;color:var(--rock-dark)">
                    {book.frontmatter.year < 0 ? `${Math.abs(book.frontmatter.year)} BCE` : book.frontmatter.year}
                  </span>
                </div>
                <h3 class="bcf-title">{book.frontmatter.title}</h3>
                <p class="bcf-takeaway"><em>"{book.frontmatter.takeaway}"</em></p>
                <div class="bcf-reading-badge">
                  <span class="currently-dot"></span>
                  <span class="mono" style="font-size:0.65rem;color:var(--parchment)">in progress</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      {completed.length > 0 && (
        <div class="books-group">
          <h2 class="group-title">Completed</h2>
          <div class="books-list">
            {completed.map((book, i) => (
              <a href={`/books/${book.frontmatter.slug}`} class="book-row" style={`animation-delay:${i * 0.07}s`}>
                <div class="book-row-left">
                  <h3 class="book-row-title">{book.frontmatter.title}</h3>
                  <div class="book-row-meta">
                    <span class="mono" style="font-size:0.7rem;color:var(--parchment)">{book.frontmatter.author}</span>
                    <span class="mono" style="font-size:0.7rem;color:var(--rock-dark)">·</span>
                    <span class="mono" style="font-size:0.7rem;color:var(--rock-dark)">
                      {book.frontmatter.year < 0 ? `${Math.abs(book.frontmatter.year)} BCE` : book.frontmatter.year}
                    </span>
                  </div>
                </div>
                <p class="book-row-takeaway"><em>"{book.frontmatter.takeaway}"</em></p>
                <div class="book-row-arrow">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <path d="M4 9h10M10 5l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>

</Base>

<style>
.page-hero {
  padding: calc(var(--nav-height) + var(--space-3xl)) 0 var(--space-2xl);
}

.page-sub {
  max-width: 520px;
  margin-top: 0.75rem;
  font-size: 1rem;
}

.books-section { padding-bottom: var(--space-3xl); }

.books-group { margin-bottom: var(--space-3xl); }

.group-title {
  font-family: var(--font-ui);
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--rock-mid);
  margin-bottom: var(--space-xl);
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.currently-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--parchment);
  flex-shrink: 0;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.books-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-md);
}

.book-card-full {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  text-decoration: none;
  animation: fadeUp 0.6s var(--ease-out) both;
}

.bcf-meta {
  display: flex;
  justify-content: space-between;
}

.bcf-title {
  font-family: var(--font-display);
  font-size: 1.2rem;
  font-weight: 400;
  color: var(--rock-white);
  line-height: 1.3;
}

.bcf-takeaway {
  font-family: var(--font-body);
  font-size: 0.85rem;
  color: var(--rock-mid);
  line-height: 1.6;
  flex: 1;
}

.bcf-reading-badge {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  margin-top: 0.25rem;
}

/* List rows for completed */
.books-list {
  display: flex;
  flex-direction: column;
}

.book-row {
  display: grid;
  grid-template-columns: 1fr 1fr auto;
  gap: 1.5rem;
  align-items: center;
  padding: var(--space-lg) 0;
  border-bottom: 1px solid var(--slate);
  text-decoration: none;
  transition: padding-left 0.25s var(--ease-out);
  animation: fadeUp 0.6s var(--ease-out) both;
}

.book-row:first-child { border-top: 1px solid var(--slate); }
.book-row:hover { padding-left: 0.5rem; }

.book-row-title {
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 400;
  color: var(--rock-white);
  margin-bottom: 0.3rem;
  line-height: 1.3;
}

.book-row-meta {
  display: flex;
  align-items: center;
  gap: 0.4rem;
}

.book-row-takeaway {
  font-family: var(--font-body);
  font-size: 0.82rem;
  color: var(--rock-mid);
  line-height: 1.55;
  font-style: italic;
}

.book-row-arrow {
  color: var(--parchment);
  opacity: 0;
  transform: translateX(-4px);
  transition: opacity 0.2s, transform 0.2s;
}

.book-row:hover .book-row-arrow {
  opacity: 1;
  transform: translateX(0);
}

@media (max-width: 700px) {
  .book-row {
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }
  .book-row-arrow { display: none; }
}
</style>
