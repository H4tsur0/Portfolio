---
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const projectModules = import.meta.glob('../../content/projects/*.md', { eager: true });
  const projects = Object.values(projectModules).map((mod: any) => mod.frontmatter ? mod : { frontmatter: mod.default });
  return projects.map((project: any) => ({
    params: { slug: project.frontmatter.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = project;
const { frontmatter } = project;
---

<Base title={`${frontmatter.title} — Richard Axel Gunawan`} current="/projects">
  <article class="container project-detail">
    <header class="project-header">
      <div class="project-meta">
        <span class={`tag ${frontmatter.status === 'in-progress' ? 'wip' : 'cyber'}`}>
          {frontmatter.status === 'in-progress' ? 'in progress' : frontmatter.category}
        </span>
        <span class="mono">{frontmatter.date}</span>
      </div>
      <h1>{frontmatter.title}</h1>
      <p class="project-summary">{frontmatter.description}</p>
      
      <div class="project-tech">
        {frontmatter.stack.map(s => <span class="tag">{s}</span>)}
      </div>
    </header>

    <div class="content-grid">
      <div class="markdown-content">
        <Content />
      </div>

      <aside class="project-sidebar">
        {frontmatter.outcome && (
          <div class="sidebar-box">
            <h3 class="mono">Outcome</h3>
            <p>{frontmatter.outcome}</p>
          </div>
        )}
        <div class="sidebar-box">
          <h3 class="mono">Role</h3>
          <p>Security Research & Implementation</p>
        </div>
      </aside>
    </div>

    <footer class="project-footer">
      <a href="/projects" class="link-more">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="transform: rotate(180deg)">
          <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Back to projects
      </a>
    </footer>
  </article>
</Base>

<style>
.project-detail {
  padding-top: calc(var(--nav-height) + var(--space-3xl));
  padding-bottom: var(--space-3xl);
}

.project-header {
  margin-bottom: var(--space-3xl);
  max-width: 800px;
}

.project-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1rem;
}

.project-header h1 {
  font-size: clamp(2.5rem, 6vw, 4rem);
  margin-bottom: 1.5rem;
  color: var(--rock-white);
}

.project-summary {
  font-size: 1.2rem;
  color: var(--rock-light);
  line-height: 1.6;
  margin-bottom: 2rem;
}

.project-tech {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.content-grid {
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: 4rem;
  align-items: start;
}

.markdown-content {
  font-family: var(--font-body);
  color: var(--rock-pale);
  line-height: 1.8;
}

.markdown-content :global(h2) {
  color: var(--rock-white);
  margin-top: 3rem;
  margin-bottom: 1rem;
  font-family: var(--font-display);
}

.markdown-content :global(p) { margin-bottom: 1.5rem; }

.project-sidebar {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.sidebar-box {
  padding: 1.5rem;
  background: var(--depth);
  border: 1px solid var(--slate);
  border-radius: 12px;
}

.sidebar-box h3 {
  font-size: 0.7rem;
  text-transform: uppercase;
  color: var(--surface);
  margin-bottom: 0.75rem;
}

.sidebar-box p {
  font-size: 0.9rem;
  color: var(--rock-pale);
  line-height: 1.5;
}

.project-footer {
  margin-top: 5rem;
  padding-top: 2rem;
  border-top: 1px solid var(--slate);
}

@media (max-width: 900px) {
  .content-grid { grid-template-columns: 1fr; }
  .project-sidebar { order: -1; }
}
</style>
